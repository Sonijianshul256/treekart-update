rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 0. Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // 0. Helpers
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isAdmin() { return isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid)); }
    function isManager() { return isSignedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'farm_manager'; }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }

    // 1. User Rules
    match /users/{userId} {
      function isValidUser(data) {
        return data.keys().hasAll(['uid', 'email', 'role']) &&
               data.keys().size() <= 6 &&
               data.uid == request.auth.uid &&
               data.email is string && data.email.size() <= 100 &&
               data.role in ['subscriber', 'corporate_admin', 'farm_manager', 'admin'];
      }
      
      allow get: if isSignedIn();
      allow create: if isSignedIn() && isValidUser(incoming()) && userId == request.auth.uid;
      allow update: if isOwner(userId) && isValidUser(incoming()) && 
                    incoming().diff(existing()).affectedKeys().hasOnly(['name', 'photoURL', 'subscriptionId']);
    }

    // 2. Tree Rules
    match /trees/{treeId} {
      function isValidTree(data) {
        return data.keys().hasAll(['id', 'type', 'location', 'status']) &&
               data.id is string && data.id.size() <= 64 &&
               data.type in ['Papaya', 'Mango'] &&
               data.status in ['available', 'rented', 'retired'] &&
               data.location.lat is number && data.location.lng is number;
      }

      allow list, get: if isSignedIn();
      allow create: if isManager() || isAdmin();
      allow update: if (isManager() || isAdmin()) || 
                    (isSignedIn() && incoming().diff(existing()).affectedKeys().hasOnly(['ownerId', 'status']) && 
                    incoming().status == 'rented' && existing().status == 'available');
      
      // Updates subcollection
      match /updates/{updateId} {
        allow read: if isSignedIn();
        allow create: if isManager() || isAdmin();
      }
    }

    // 3. Subscription Rules
    match /subscriptions/{subId} {
      function isValidSub(data) {
        return data.keys().hasAll(['id', 'userId', 'treeId', 'type']) &&
               data.userId == request.auth.uid &&
               data.treeId is string &&
               data.type in ['individual', 'shared', 'b2b'];
      }

      allow get: if isSignedIn() && (resource.data.userId == request.auth.uid || 
                  resource.data.coOwnerEmail == request.auth.token.email);
      allow create: if isSignedIn() && isValidSub(incoming()) && 
                    existsAfter(/databases/$(database)/documents/trees/$(incoming().treeId)) &&
                    getAfter(/databases/$(database)/documents/trees/$(incoming().treeId)).data.status == 'rented';
    }

    // 4. Admin Bootstrap
    match /admins/{adminId} {
      allow read: if isSignedIn();
    }
  }
}
