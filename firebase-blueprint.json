{
  "entities": {
    "User": {
      "title": "User",
      "description": "App users including subscribers and staff",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["subscriber", "corporate_admin", "farm_manager", "admin"] },
        "subscriptionId": { "type": "string" },
        "photoURL": { "type": "string" }
      },
      "required": ["uid", "email", "role"]
    },
    "Tree": {
      "title": "Tree",
      "description": "A fruit tree asset",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "type": { "type": "string", "enum": ["Papaya", "Mango"] },
        "location": { "type": "object" },
        "status": { "type": "string", "enum": ["available", "rented", "retired"] },
        "price": { "type": "number" },
        "plantedDate": { "type": "string", "format": "date-time" },
        "ownerId": { "type": "string" },
        "growthStage": { "type": "number" },
        "health": { "type": "string" }
      },
      "required": ["id", "type", "location", "status"]
    },
    "Subscription": {
      "title": "Subscription",
      "description": "Tree rental contract",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "treeId": { "type": "string" },
        "type": { "type": "string", "enum": ["individual", "shared", "b2b"] },
        "startDate": { "type": "string", "format": "date-time" },
        "endDate": { "type": "string", "format": "date-time" },
        "amount": { "type": "number" },
        "coOwnerEmail": { "type": "string" }
      },
      "required": ["id", "userId", "treeId", "type"]
    },
    "Update": {
      "title": "Update",
      "description": "Daily tree status update",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "treeId": { "type": "string" },
        "photoURL": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "location": { "type": "object" },
        "soilMoisture": { "type": "number" }
      },
      "required": ["id", "treeId", "photoURL", "timestamp"]
    },
    "SystemUpdate": {
      "title": "System Update",
      "description": "In-app notification or system message",
      "type": "object",
      "properties": {
        "recipientId": { "type": "string" },
        "title": { "type": "string" },
        "body": { "type": "string" },
        "type": { "type": "string" },
        "timestamp": { "type": "string" }
      },
      "required": ["recipientId", "title", "body"]
    },
    "FCMToken": {
      "title": "FCM Token",
      "description": "Push notification token for a user",
      "type": "object",
      "properties": {
        "token": { "type": "string" },
        "updatedAt": { "type": "string" }
      },
      "required": ["token", "updatedAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/trees/{treeId}": {
      "schema": "Tree",
      "description": "Tree inventory"
    },
    "/subscriptions/{subId}": {
      "schema": "Subscription",
      "description": "Active contracts"
    },
    "/trees/{treeId}/updates/{updateId}": {
      "schema": "Update",
      "description": "Periodic tree tracking"
    },
    "/system_updates/{updateId}": {
      "schema": "SystemUpdate",
      "description": "User-specific notifications"
    },
    "/fcm_tokens/{userId}": {
      "schema": "FCMToken",
      "description": "Push notification mappings"
    }
  }
}
